# Search with ripgrep, open in Neovim
vrgi() {
  local results=$(rg -il "$@")
  if [[ -n "$results" ]]; then
    echo "$results" | xargs nvim
  else
    echo "No files found containing: $@"
  fi
}

vrg() {
  local results=$(rg -l "$@")
  if [[ -n "$results" ]]; then
    echo "$results" | xargs nvim
  else
    echo "No files found containing: $@"
  fi
}

