function _git_default_branch {
  local ref branch
  ref=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)
  if [[ -n "$ref" ]]; then
    branch="${ref#origin/}"
    if git show-ref --verify --quiet "refs/remotes/origin/${branch}"; then
      echo "${branch}"
      return 0
    fi
  fi

  if git show-ref --verify --quiet refs/remotes/origin/master; then
    echo "master"
    return 0
  fi
  if git show-ref --verify --quiet refs/remotes/origin/main; then
    echo "main"
    return 0
  fi

  return 1
}

function _git_switch_to_branch {
  local branch="$1"

  if git show-ref --verify --quiet "refs/heads/${branch}"; then
    git switch "$branch"
    return $?
  fi

  git switch --track -c "$branch" "origin/$branch"
}

function _git_sync_default_branch {
  local branch="$1"

  git fetch origin || return 1
  _git_switch_to_branch "$branch" || return 1
  git merge --ff-only "origin/$branch"
}

function gil {
  gal "$@"
}

function gal {
  local branch
  if ! git remote get-url origin >/dev/null 2>&1; then
    echo "❌ No 'origin' remote configured in this repo. Add one with: git remote add origin <url>"
    return 1
  fi
  branch=$(_git_default_branch) || {
    echo "❌ Could not determine remote default branch (expected origin/HEAD, origin/master, or origin/main)."
    echo "   Try: git remote set-head origin --auto"
    return 1
  }

  _git_sync_default_branch "$branch"
}

