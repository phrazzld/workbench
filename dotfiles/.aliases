# --- TMUX SESSION MANAGEMENT ---
alias rdev='zellij-remote'                  # start/attach remote dev session (zellij; survives mosh/Blink drops)
alias tma='tmux attach -t'                  # attach by name: tma dev
alias tmd='tmux detach'                     # detach current session
alias tms='tmux list-sessions'              # list sessions
alias tmw='tmux list-windows'               # list windows in current session
alias tmk='tmux kill-session -t'            # kill by name: tmk remote
alias tmka='tmux kill-server'               # nuclear: kill all sessions
alias tmn='tmux new-window -c "$(pwd)"'     # new window in cwd
alias tmr='tmux rename-window'              # rename current window
alias tmsw='tmux swap-window -t'            # swap window position
alias tmsp='tmux split-window -h -c "$(pwd)"'  # vertical split in cwd
alias tmvs='tmux split-window -v -c "$(pwd)"'  # horizontal split in cwd

# Quick session switching (fzf-powered)
tms-switch() {
  local target
  target=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | fzf --prompt="session> ") || return
  tmux switch-client -t "$target"
}
alias tmsf='tms-switch'

# Quick window switching (fzf-powered)
tmw-switch() {
  local target
  target=$(tmux list-windows -F '#{window_index}: #{window_name}' 2>/dev/null | fzf --prompt="window> " | cut -d: -f1) || return
  tmux select-window -t "$target"
}
alias tmwf='tmw-switch'

# Send command to a named window (useful for remote orchestration)
# Usage: tm-send work "git pull && make test"
tm-send() {
  local window="${1:?window name required}"
  local cmd="${2:?command required}"
  tmux send-keys -t "$window" "$cmd" C-m
}

# --- ZELLIJ SESSION MANAGEMENT ---
alias zls='zellij ls'                       # list sessions (live + exited)
alias zlsn='zellij ls -sn'                  # names only, ANSI-stripped (pipe-friendly)
alias zd='zellij action detach'             # detach without chord

# --- ZELLIJ TABS ---
# `zw` — fuzzy, full-list tab switcher (room plugin); "zellij window", à la tmux.
# Works in the CURRENT session, unlike the Alt+t keybind which only applies to
# sessions started after a config change. Type to filter, Enter to jump, or press
# a tab's number. (NOT named `tabs`: that's a real POSIX command that sets
# terminal tab stops and spews escape codes when the alias isn't loaded.)
alias zw='zellij action launch-or-focus-plugin --floating --configuration "ignore_case=true,quick_jump=true" "file:$HOME/.config/zellij/plugins/room.wasm"'

# `zn <name>` — quick manual tab rename.
zn() { zellij action rename-tab "${1:?usage: zn <tab name>}"; }

# Auto-name UNNAMED tabs (still called "Tab #N") to the git-repo / dir basename
# when a shell starts. Never clobbers tabs you've named yourself (aesthetic,
# olympus, …) — it only fires when the focused tab still has its default name.
if [[ -n "$ZELLIJ" ]]; then
  _zj_autoname() {
    # Interactive shells only: don't spend a zellij IPC (or rename a tab) from
    # non-interactive script/tool shells that also source this file.
    [[ -o interactive ]] || return 0
    local cur name
    cur="$(zellij action current-tab-info 2>/dev/null | awk -F': ' '/^name:/{print $2}')"
    [[ "$cur" == "Tab #"* ]] || return 0
    name="$(basename "$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")")"
    [[ -n "$name" ]] && zellij action rename-tab "$name" 2>/dev/null
  }
  _zj_autoname
fi

# Attach-or-create: session name defaults to cwd basename
zat() { zellij attach -c "${1:-$(basename "$PWD")}"; }

# Kill a session (keeps serialized state for later resurrection)
zkill() { zellij kill-session "${1:?session name required}"; }

# Delete a session (wipes serialized state — permanent)
zrm() { zellij delete-session -f "${1:?session name required}"; }

# Fuzzy swap: pick any session by name via fzf
zsw() {
  local target
  target=$(zellij ls -sn 2>/dev/null | fzf --prompt="session> " --height=40% --reverse) || return
  if [ -n "$ZELLIJ_SESSION_NAME" ]; then
    zellij action switch-session "$target"
  else
    zellij attach -c "$target"
  fi
}

# Alt-Tab between sessions: tracks last-used, toggles back and forth
zt() {
  local state="$HOME/.cache/zellij-last-session"
  local current="$ZELLIJ_SESSION_NAME"
  [ -z "$current" ] && { echo "not in a zellij session" >&2; return 1; }
  mkdir -p "$(dirname "$state")"
  local target
  if [ -f "$state" ] && [ "$(cat "$state")" != "$current" ]; then
    target=$(cat "$state")
  else
    target=$(zellij ls -sn 2>/dev/null | grep -v "^${current}\$" | head -1)
  fi
  [ -z "$target" ] && { echo "no other session" >&2; return 1; }
  echo "$current" > "$state"
  zellij action switch-session "$target"
}

