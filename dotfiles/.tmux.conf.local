# : << EOF
# Oh my tmux! — Rose Pine theme
# Sharp powerline: colored segments with arrow transitions
#
# https://github.com/gpakosz/.tmux
# (‑●‑●)> dual licensed under the WTFPL v2 license and the MIT license,
#         without any warranty.
#         Copyright 2012— Gregory Pakosz (@gpakosz).
#
# Managed in codex project dotfiles/


# -- bindings ------------------------------------------------------------------

tmux_conf_preserve_stock_bindings=false


# -- session creation ----------------------------------------------------------

tmux_conf_new_session_prompt=false
tmux_conf_new_session_retain_current_path=false


# -- windows & pane creation ---------------------------------------------------

tmux_conf_new_window_retain_current_path=true
tmux_conf_new_window_reconnect_ssh=false
tmux_conf_new_pane_retain_current_path=true
tmux_conf_new_pane_reconnect_ssh=false


# -- display -------------------------------------------------------------------

tmux_conf_24b_colour=auto


# -- theming -------------------------------------------------------------------

tmux_conf_theme=enabled

# Rose Pine (dark) palette
tmux_conf_theme_colour_1="#191724"    # base
tmux_conf_theme_colour_2="#1f1d2e"    # surface
tmux_conf_theme_colour_3="#6e6a86"    # muted
tmux_conf_theme_colour_4="#f6c177"    # gold — primary accent
tmux_conf_theme_colour_5="#ebbcba"    # rose
tmux_conf_theme_colour_6="#191724"    # base
tmux_conf_theme_colour_7="#e0def4"    # text
tmux_conf_theme_colour_8="#1f1d2e"    # surface
tmux_conf_theme_colour_9="#f6c177"    # gold
tmux_conf_theme_colour_10="#c4a7e7"   # iris — purple
tmux_conf_theme_colour_11="#31748f"   # pine — teal
tmux_conf_theme_colour_12="#26233a"   # overlay
tmux_conf_theme_colour_13="#e0def4"   # bright text
tmux_conf_theme_colour_14="#191724"   # base
tmux_conf_theme_colour_15="#1f1d2e"   # surface
tmux_conf_theme_colour_16="#eb6f92"   # love — red
tmux_conf_theme_colour_17="#e0def4"   # text

# window style
tmux_conf_theme_window_fg="default"
tmux_conf_theme_window_bg="default"

# highlight focused pane
tmux_conf_theme_highlight_focused_pane=false
tmux_conf_theme_focused_pane_bg="$tmux_conf_theme_colour_2"

# pane border style
tmux_conf_theme_pane_border_style=thin

# pane borders — gold glow on active
tmux_conf_theme_pane_border="#403d52"
tmux_conf_theme_pane_active_border="$tmux_conf_theme_colour_4"

# pane indicator colours (prefix + q)
tmux_conf_theme_pane_indicator="$tmux_conf_theme_colour_4"
tmux_conf_theme_pane_active_indicator="$tmux_conf_theme_colour_4"

# status line message style — dark on gold
tmux_conf_theme_message_fg="$tmux_conf_theme_colour_1"
tmux_conf_theme_message_bg="$tmux_conf_theme_colour_4"
tmux_conf_theme_message_attr="none"

# status line command style (prefix : Escape)
tmux_conf_theme_message_command_fg="$tmux_conf_theme_colour_4"
tmux_conf_theme_message_command_bg="$tmux_conf_theme_colour_1"
tmux_conf_theme_message_command_attr="none"

# window modes style
tmux_conf_theme_mode_fg="$tmux_conf_theme_colour_1"
tmux_conf_theme_mode_bg="$tmux_conf_theme_colour_4"
tmux_conf_theme_mode_attr="none"

# status line style — base background
tmux_conf_theme_status_fg="$tmux_conf_theme_colour_3"
tmux_conf_theme_status_bg="$tmux_conf_theme_colour_1"
tmux_conf_theme_status_attr="none"

# terminal title
tmux_conf_theme_terminal_title="#h ❐ #S ● #I #W"

# -- window status -------------------------------------------------------------

# inactive windows — muted
tmux_conf_theme_window_status_fg="$tmux_conf_theme_colour_3"
tmux_conf_theme_window_status_bg="$tmux_conf_theme_colour_1"
tmux_conf_theme_window_status_attr="none"
tmux_conf_theme_window_status_format="  #I  "

# active window — gold on overlay
tmux_conf_theme_window_status_current_fg="$tmux_conf_theme_colour_4"
tmux_conf_theme_window_status_current_bg="$tmux_conf_theme_colour_12"
tmux_conf_theme_window_status_current_attr="none"
tmux_conf_theme_window_status_current_format="  #I:#W  "

# activity — gold
tmux_conf_theme_window_status_activity_fg="$tmux_conf_theme_colour_4"
tmux_conf_theme_window_status_activity_bg="default"
tmux_conf_theme_window_status_activity_attr="none"

# bell — love blink
tmux_conf_theme_window_status_bell_fg="$tmux_conf_theme_colour_16"
tmux_conf_theme_window_status_bell_bg="default"
tmux_conf_theme_window_status_bell_attr="blink"

# last window — subtle
tmux_conf_theme_window_status_last_fg="#908caa"
tmux_conf_theme_window_status_last_bg="$tmux_conf_theme_colour_1"
tmux_conf_theme_window_status_last_attr="none"

# -- separators ----------------------------------------------------------------

# sharp powerline arrows
tmux_conf_theme_left_separator_main='\uE0B0'
tmux_conf_theme_left_separator_sub='\uE0B1'
tmux_conf_theme_right_separator_main='\uE0B2'
tmux_conf_theme_right_separator_sub='\uE0B3'

# -- status left/right --------------------------------------------------------
#
# Sharp powerline: colored segments separated by | with arrow transitions.
# Oh My Tmux draws \uE0B0 between left sections and \uE0B2 between right.

# Left: [gold: ◈ session] ▶ [overlay: path ⎇ branch]
tmux_conf_theme_status_left=" ◈ #S | #{b:pane_current_path}#[fg=$tmux_conf_theme_colour_10]#(cd #{pane_current_path}; git branch --show-current 2>/dev/null | head -c 16 | sed 's/.*/ ⎇ &/') "

# 2 sections: gold → overlay
tmux_conf_theme_status_left_fg="$tmux_conf_theme_colour_1,$tmux_conf_theme_colour_7"
tmux_conf_theme_status_left_bg="$tmux_conf_theme_colour_4,$tmux_conf_theme_colour_12"
tmux_conf_theme_status_left_attr="none,none"

# Right: [overlay: time] ◀ [iris: date]
tmux_conf_theme_status_right=" %H:%M | %d %b "

# 2 sections: overlay → iris
tmux_conf_theme_status_right_fg="#908caa,$tmux_conf_theme_colour_1"
tmux_conf_theme_status_right_bg="$tmux_conf_theme_colour_12,$tmux_conf_theme_colour_10"
tmux_conf_theme_status_right_attr="none,none"

# -- indicators ----------------------------------------------------------------

tmux_conf_theme_pairing="⚇"
tmux_conf_theme_pairing_fg="none"
tmux_conf_theme_pairing_bg="none"
tmux_conf_theme_pairing_attr="none"

tmux_conf_theme_prefix="⌨"
tmux_conf_theme_prefix_fg="none"
tmux_conf_theme_prefix_bg="none"
tmux_conf_theme_prefix_attr="none"

tmux_conf_theme_mouse="↗"
tmux_conf_theme_mouse_fg="none"
tmux_conf_theme_mouse_bg="none"
tmux_conf_theme_mouse_attr="none"

tmux_conf_theme_root="!"
tmux_conf_theme_root_fg="none"
tmux_conf_theme_root_bg="none"
tmux_conf_theme_root_attr="blink"

tmux_conf_theme_synchronized="⚏"
tmux_conf_theme_synchronized_fg="none"
tmux_conf_theme_synchronized_bg="none"
tmux_conf_theme_synchronized_attr="none"

# -- battery -------------------------------------------------------------------

tmux_conf_battery_bar_symbol_full="◼"
tmux_conf_battery_bar_symbol_empty="◻"
tmux_conf_battery_bar_length="auto"
tmux_conf_battery_bar_palette="gradient"
tmux_conf_battery_hbar_palette="gradient"
tmux_conf_battery_vbar_palette="gradient"
tmux_conf_battery_status_charging=""
tmux_conf_battery_status_discharging=""

# clock — gold
tmux_conf_theme_clock_colour="$tmux_conf_theme_colour_4"
tmux_conf_theme_clock_style="24"


# -- clipboard -----------------------------------------------------------------

tmux_conf_copy_to_os_clipboard=true


# -- urlscan -------------------------------------------------------------------

tmux_conf_urlscan_options="--compact --dedupe"


# -- user customizations -------------------------------------------------------

# increase history size
set -g history-limit 10000

# mouse
set -g mouse on

# force Vi mode
set -g status-keys vi
set -g mode-keys vi

# ensure next/previous window bindings are intact
bind n next-window
bind p previous-window

# copy mode (vim-style)
bind Escape copy-mode
bind -T copy-mode-vi v send-keys -X begin-selection
bind -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "pbcopy"
bind -T copy-mode-vi C-v send-keys -X rectangle-toggle
bind P paste-buffer

# vim-style pane navigation
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# vim-style window navigation
bind -r C-h select-window -t :-
bind -r C-l select-window -t :+

# resize panes
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# reload configuration
bind r source-file ~/.tmux.conf \; display-message "Config reloaded!"

# clear screen and history
bind C-k send-keys C-l \; clear-history

# activity alerts without visual noise
setw -g monitor-activity on
set -g visual-activity off

# focus events for vim/neovim
set -g focus-events on

# faster escape time
set -sg escape-time 0

# longer display time for messages
set -g display-time 2000

# status line
set -g status-position top #!important
set -g status-justify centre #!important
set -g status-left-length 100 #!important
set -g status-right-length 80 #!important
set -g status-interval 5 #!important
set -g status on #!important

# Rose Pine base background
set -g status-style "bg=$tmux_conf_theme_colour_1" #!important
set -g window-status-activity-style "fg=$tmux_conf_theme_colour_4,bg=default,none" #!important

# pane borders
set -g pane-border-style "fg=#403d52" #!important
set -g pane-active-border-style "fg=#f6c177" #!important


# -- tpm -----------------------------------------------------------------------

tmux_conf_update_plugins_on_launch=true
tmux_conf_update_plugins_on_reload=true
tmux_conf_uninstall_plugins_on_reload=true


# -- custom variables ----------------------------------------------------------

# /!\ do not remove the following line
# EOF
#
# /!\ do not "uncomment" the functions: the leading "# " characters are needed
#
# "$@"
# /!\ do not remove the previous line
#     do not write below this line
