# Explicit, value-free runtime routes for Roster children. Roster strips the
# ROSTER_CHILD_ENV_ prefix only after clearing the inherited environment.
ROSTER_CHILD_ENV_MINT_BASE_URL=http://mint.tail5f5eb4.ts.net:4949

ROSTER_CHILD_ENV_CANARY_ENDPOINT=${ROSTER_CHILD_ENV_MINT_BASE_URL}/proxy/https/canary.mistystep.io
ROSTER_CHILD_ENV_CANARY_API_KEY=__mint.canary.default__

ROSTER_CHILD_ENV_XAI_BASE_URL=${ROSTER_CHILD_ENV_MINT_BASE_URL}/proxy/https/api.x.ai/v1

ROSTER_CHILD_ENV_DEEPGRAM_BASE_URL=${ROSTER_CHILD_ENV_MINT_BASE_URL}/proxy/https/api.deepgram.com/v1
