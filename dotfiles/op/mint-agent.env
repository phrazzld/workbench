# Non-secret environment for agent processes. Every credential-shaped value is
# a Mint placeholder and is paired with a proxy URL, so a client cannot send the
# placeholder directly to the vendor by accident.
MINT_BASE_URL=http://mint.tail5f5eb4.ts.net:4949

CANARY_ENDPOINT=${MINT_BASE_URL}/proxy/https/canary.mistystep.io
CANARY_API_KEY=__mint.canary.default__

XAI_BASE_URL=${MINT_BASE_URL}/proxy/https/api.x.ai/v1

DEEPGRAM_BASE_URL=${MINT_BASE_URL}/proxy/https/api.deepgram.com/v1
